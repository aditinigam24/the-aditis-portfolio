# .env.example
# Contact form (Gmail app password — 16 chars, spaces optional)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password_here

# Jerry chatbot — Groq free key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional backup — https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Server
SERVER_PORT=3001
NODE_ENV=development
VITE_API_URL=https://the-aditis-portfolio.onrender.com
